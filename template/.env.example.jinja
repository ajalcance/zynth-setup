# ==============================================================================
# {{ project_name }} — Environment Template
# ==============================================================================
# Copy to `.env` and fill in REAL values locally / on the server ONLY.
#   cp .env.example .env
# The real .env is NEVER committed. Placeholders below are intentionally fake.
# ==============================================================================

# --- Runtime ---
# ENVIRONMENT is the source of truth for runtime mode. Outside `development` the config
# validator fails closed: real secrets are REQUIRED (no insecure fallback).
ENVIRONMENT=development
LOG_LEVEL=info

# --- Application secrets (REQUIRED outside development) ---
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# --- Database ---
{% if include_deploy -%}
DATABASE_URL=postgresql+asyncpg://appuser:CHANGE_ME_STRONG_PASSWORD@postgres:5432/appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=appdb
{%- else -%}
DATABASE_URL=postgresql+asyncpg://user:CHANGE_ME@localhost:5432/{{ python_package }}
{%- endif %}
{% if include_compliance_spine %}
# --- Redis (compliance spine) ---
REDIS_URL=redis://{% if include_deploy %}redis{% else %}localhost{% endif %}:6379/0
{%- endif %}
